# Yealink YMCS (Management Cloud Service) - OAuth2 credentials
# Obtain from YMCS portal: Enterprise > Open API > Client Credentials
YMCS_CLIENT_ID=
YMCS_CLIENT_SECRET=
YMCS_API_URL=https://api-dm.yealink.com:8445

# Yealink RPS (Remote Provisioning Service)
# Credentials from rps.yealink.com account
RPS_USERNAME=
RPS_PASSWORD=
RPS_API_URL=https://rps.yealink.com

# Optional
DEBUG=false
